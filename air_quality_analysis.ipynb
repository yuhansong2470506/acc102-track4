# Air Quality Data Analysis Notebook

# 1. Import Libraries
import pandas as pd
import matplotlib.pyplot as plt
import plotly.express as px

# 2. Load Data
df = pd.read_csv("air_quality.csv")
df["Date"] = pd.to_datetime(df["Date"])
df.head()

# 3. Basic Information
print("Data shape:", df.shape)
print("\nData types:")
print(df.dtypes)
print("\nMissing values:")
print(df.isnull().sum())

# 4. Data Cleaning
df = df.dropna()
df = df[(df["AQI"] >= 0) & (df["AQI"] <= 500)]

df["Month"] = df["Date"].dt.month
df["Season"] = df["Date"].dt.month.map({
1:"Winter",2:"Winter",3:"Spring",4:"Spring",5:"Spring",
6:"Summer",7:"Summer",8:"Summer",9:"Autumn",10:"Autumn",
11:"Autumn",12:"Winter"
})

print("Cleaned data shape:", df.shape)

# 5. Descriptive Statistics
df[["AQI","PM2.5","PM10","SO2","NO2","CO","O3"]].describe()

# 6. City AQI Comparison
city_aqi = df.groupby("City")["AQI"].mean().sort_values(ascending=False)
print("Average AQI by City:")<br/>print(city_aqi)

# 7. AQI Trend Over Time
daily_aqi = df.groupby(["Date","City"])["AQI"].mean().reset_index()
fig = px.line(daily_aqi, x="Date", y="AQI", color="City", title="AQI Trend")
fig.show()

# 8. Pollutant Distribution
fig = px.box(df, x="City", y="PM2.5", title="PM2.5 by City")
fig.show()

# 9. Air Quality Level Proportion
level_count = df["Quality_Level"].value_counts().reset_index()
level_count.columns = ["Quality_Level","Count"]
fig = px.pie(level_count, values="Count", names="Quality_Level", title="Air Quality Level")
fig.show()

# 10. Seasonal Analysis
season_aqi = df.groupby(["Season","City"])["AQI"].mean().reset_index()
fig = px.bar(season_aqi, x="Season", y="AQI", color="City", barmode="group")
fig.show()

# 11. Key Findings
print("1. AQI is highest in winter and lowest in summer.")
print("2. PM2.5 is the main pollutant.")
print("3. Air quality varies between different cities.")
print("4. Most days are Good or Moderate level.")
